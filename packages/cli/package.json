{
  "name": "@nodalkit/nodalkit",
  "version": "1.0.2",
  "bin": {
    "nodalkit": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "pack:dry": "bun run build && bun pm pack --dry-run",
    "prepublishOnly": "bun update && bun run build"
  },
  "dependencies": {
    "@nodalkit/nodalkit-core": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "gradient-string": "^3.0.0",
    "ora": "^9.4.1",
    "zod": "^4.4.3"
  }
}
